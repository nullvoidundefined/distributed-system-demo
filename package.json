{
    "name": "distributed-system-demo",
    "private": true,
    "type": "module",
    "workspaces": [
        "shared",
        "server",
        "worker",
        "web"
    ],
    "scripts": {
        "build": "npm run build -ws --if-present",
        "dev": "concurrently -n server,web -c blue,green \"npm:dev:server\" \"npm:dev:web\"",
        "dev:server": "npm run dev -w server",
        "dev:web": "npm run dev -w web",
        "redis:start": "redis-server --port 6379 --save \"\" --appendonly no --daemonize yes",
        "redis:stop": "redis-cli -p 6379 shutdown nosave || true",
        "test": "npm run test -ws --if-present"
    },
    "devDependencies": {
        "concurrently": "^9.1.0",
        "prettier": "^3.3.3",
        "typescript": "^5.6.0"
    }
}
